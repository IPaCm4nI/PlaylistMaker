<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imagePlaylist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        tools:src="@tools:sample/avatars"

        android:layout_marginHorizontal="@dimen/dp_4"
        android:layout_marginTop="@dimen/dp_16"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"

        app:shapeAppearanceOverlay="@style/RoundedPlaylistImage"
        />

    <TextView
        android:id="@+id/titlePlaylist"
        android:layout_width="0dp"
        android:layout_height="match_parent"

        app:layout_constraintStart_toStartOf="@id/imagePlaylist"
        app:layout_constraintEnd_toEndOf="@id/imagePlaylist"
        app:layout_constraintTop_toBottomOf="@id/imagePlaylist"

        android:layout_marginTop="@dimen/dp_4"
        style="@style/TextPlaylist"

        tools:text="Best songs 2021"
        />

    <TextView
        android:id="@+id/countTracks"
        android:layout_width="0dp"
        android:layout_height="match_parent"

        app:layout_constraintStart_toStartOf="@id/imagePlaylist"
        app:layout_constraintEnd_toEndOf="@id/imagePlaylist"
        app:layout_constraintTop_toBottomOf="@id/titlePlaylist"

        style="@style/TextPlaylist"

        tools:text="98 треков"
        />

</androidx.constraintlayout.widget.ConstraintLayout>